#the conditional statement includes if, elif and else
#the "else" conditional will be executed, when "if" and "elif" statement becomes false
a = 200
b = 33
if b > a:
  print("b is greater than a")
elif a == b:
  print("a and b are equal")
else:
  print("a is greater than b")

#conditional expression: the conditional statement that can be written in one line
#format: X if condition else Y
num = 283
print("EVEN" if num % 2 ==0 else "ODD")
